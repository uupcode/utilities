{
    "name": "uupcode/utilities",
    "description": "Fluent, expressive utilities for WordPress plugin development — DB, hooks, AJAX, REST,\n   assets, logging, caching, meta, post types, cron and more.",
    "version": "0.0.2",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "UupCode\\Utilities\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UupCode\\Utilities\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=1G",

        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
